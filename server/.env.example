# ── Claude Agent SDK = 구독 인증 사용 ──
# 이미 로그인된 Claude Code 구독(~/.claude/.credentials.json)을 그대로 씁니다.
# 별도 API 키/결제가 필요 없습니다. 파일명을 .env 로 바꿔 쓰세요(.gitignore 포함).

# 실제 에이전트 실행 스위치 (미설정 = 목 모드, 완전 무료)
OFFICE_LIVE=1

# ── 로그인 방법 (하나만) ──
# A) 구독 로그인:  터미널에서  claude  실행 → 브라우저 로그인 (권장)
# B) 헤드리스:     claude setup-token → 출력된 토큰을 아래에 설정
# CLAUDE_CODE_OAUTH_TOKEN=
# C) API 키(종량제): 아래 설정 (설정 시 구독 대신 API 키 모드로 전환됨)
# ANTHROPIC_API_KEY=
#
# ⚠️ 구독을 쓰려면 ANTHROPIC_API_KEY 를 설정하지 마세요(API 키가 우선순위 높음).

# 선택: 특정 Claude Code 로그인을 쓰려면 config 디렉터리 지정
#    (기본은 ~/.claude. 다른 로그인을 쓰려면 아래 주석 해제 후 경로 수정)
# CLAUDE_CONFIG_DIR=$HOME/.claude

# 선택: 모델 오버라이드. 설정하면 역할별 기본 대신 전원 이 모델로 실행(테스트용).
#   역할별 기본 = PM·개발: claude-opus-4-8 / 디자이너·QA: claude-sonnet-5 (server/src/roles.mjs)
#   ※ 구독 등급이 허용하는 모델이어야 함.
# OFFICE_MODEL=

# 선택: 포트 (기본 8787)
# PORT=8787
